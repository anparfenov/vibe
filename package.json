{
  "name": "my-site-workspace",
  "private": true,
  "packageManager": "pnpm@10.13.1",
  "devDependencies": {
    "@types/node": "^24.12.2",
    "oxfmt": "^0.2.0",
    "oxlint": "^0.18.0",
    "typescript": "~6.0.2",
    "vite": "^8.0.4",
    "vite-plugin-pwa": "^1.2.0",
    "workbox-window": "^7.4.0"
  },
  "scripts": {
    "lint": "pnpm -C packages/my-site-preact lint",
    "lint:fix": "pnpm -C packages/my-site-preact lint:fix",
    "format": "pnpm -C packages/my-site-preact format",
    "format:check": "pnpm -C packages/my-site-preact format:check",
    "dev:preact": "pnpm -C packages/my-site-preact dev",
    "dev:vue": "pnpm -C packages/my-site-vue dev",
    "build:preact": "pnpm -C packages/my-site-preact build",
    "build:vue": "pnpm -C packages/my-site-vue build"
  }
}
